{
  "name": "nextjs-mastery",
  "version": "1.0.0",
  "description": "Phase 4: Next.js curriculum (Days 18–21) — real Next.js 15 app",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "lint": "next lint",
    "challenge:01": "npx ts-node --transpile-only --project challenges/tsconfig.json challenges/c01-app-router.ts",
    "challenge:02": "npx ts-node --transpile-only --project challenges/tsconfig.json challenges/c02-data-fetching.ts",
    "challenge:03": "npx ts-node --transpile-only --project challenges/tsconfig.json challenges/c03-server-actions.ts",
    "challenge:04": "npx ts-node --transpile-only --project challenges/tsconfig.json challenges/c04-rendering-strategy.ts",
    "challenge:all": "npm run challenge:01 && npm run challenge:02 && npm run challenge:03 && npm run challenge:04"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "ts-node": "^10.9.2"
  }
}
