{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true,
    "mocha": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "indent": "off",
    "quotes": "off",
    "semi": "warn",
    "curly": "warn",
    "eqeqeq": "warn",
    "no-undef": "warn"
  }
}
